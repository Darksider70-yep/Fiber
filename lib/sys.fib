# 📂 Fiber System Utility Library

def args() {
    # sys_args would need a builtin, assuming for now
    return []
}

def platform() {
    return os_platform()
}

def cpu_count() {
    return os_cpu_count()
}

def exit(code) {
    # If we had a termination builtin, we'd use it here.
    # For now, it's a stub or uses os_exec to kill.
    return code
}

def version() {
    return "0.3.0-beta"
}
