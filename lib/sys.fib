# 📂 Fiber System Utility Library

def args() {
    # sys_args would need a builtin, assuming for now
    return []
}

def platform() {
    return os_platform()
}

def cpu_count() {
    return os_cpu_count()
}

def exit(code) {
    return code
}

def compile(path) {
    return sys_compile(path)
}

def version() {
    return "2.1.0-gold"
}
