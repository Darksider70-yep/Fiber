print "--- Functional Power ---"
var nums = [1, 2, 3, 4, 5]
# Squares using map
def square(x) { return x * x }
var squared = algo.map(nums, square)
print "Original: " + str(nums)
print "Squared:  " + str(squared)

print "--- Data Insight ---"
var scores = [85, 92, 78, 90, 88]
print "Median Score:   " + str(stats.median(scores))
print "Standard Dev:   " + str(math_round(stats.std_dev(scores), 2))

print "--- Simulation: Training Neural Model ---"
var total = 50
var pb = ProgressBar(total, "Training", "Complete", 30)

for i = 1 to total {
    # Simulate work
    var x = i * i 
    pb.update(i)
    # Slow down loop slightly (approximate)
    for j = 1 to 50000 { var y = j } 
}

print "Success: Fiber Maturity Verified."
