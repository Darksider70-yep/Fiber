# 🌟 Fiber Maturity Showcase

import sys
import datetime
import stats
import algo
from ui import ProgressBar

print "=== Fiber System Maturity ==="
print "Platform:  " + sys.platform()
print "CPU Cores: " + str(sys.cpu_count())
print "Version:   " + sys.version()
