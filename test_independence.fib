# 🧪 Testing Independence (IO & System)

import io
import sys
import json

print "--- Testing File I/O ---"
var test_file = "test_independence.txt"
var content = "Fiber is independent!"
io.write(test_file, content)

var read_back = io.read(test_file)
print "Read from file: " + read_back

print ""
print "--- Testing System ---"
print "Current Timestamp: " + str(sys.now())
# print "OS User: " + str(sys.env("USERNAME")) # Might be different on different OS

print ""
print "--- Testing JSON ---"
var data = {"name": "Fiber", "version": 0.2, "tags": ["AI", "Logic"]}
var json_text = json.stringify(data)
print "JSON String: " + json_text

var parsed = json.parse(json_text)
print "Parsed Version: " + str(parsed["version"])

print ""
print "Test Complete!"
