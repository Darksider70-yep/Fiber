{
    "name": "Fiber Astro",
    "type": "dark",
    "colors": {
        "editor.background": "#000000",
        "editor.foreground": "#e0e0e0",
        "activityBar.background": "#000000",
        "sideBar.background": "#000000",
        "statusBar.background": "#000000",
        "editorLineNumber.foreground": "#3c096c",
        "editorCursor.foreground": "#ff00ff"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#3c096c", "fontStyle": "italic" }
        },
        {
            "name": "Keywords",
            "scope": ["keyword.control", "storage.type"],
            "settings": { "foreground": "#9d4edd", "fontStyle": "bold" }
        },
        {
            "name": "Strings",
            "scope": ["string.quoted"],
            "settings": { "foreground": "#00ffff" }
        },
        {
            "name": "Numbers",
            "scope": ["constant.numeric"],
            "settings": { "foreground": "#ff00ff" }
        },
        {
            "name": "Functions",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#5a189a" }
        },
        {
            "name": "AI Support Functions",
            "scope": ["support.function.fiber"],
            "settings": { "foreground": "#c77dff", "fontStyle": "bold" }
        },
        {
            "name": "Constants",
            "scope": ["constant.language"],
            "settings": { "foreground": "#e0a1ff" }
        }
    ]
}
