{
    "name": "Fiber Sunset",
    "type": "dark",
    "colors": {
        "editor.background": "#1a0f0f",
        "editor.foreground": "#ffe5d9",
        "activityBar.background": "#1a0f0f",
        "sideBar.background": "#1a0f0f",
        "statusBar.background": "#1a0f0f",
        "editorLineNumber.foreground": "#6d5959",
        "editorCursor.foreground": "#ff4d00"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#6d5959", "fontStyle": "italic" }
        },
        {
            "name": "Keywords",
            "scope": ["keyword.control", "storage.type"],
            "settings": { "foreground": "#ff4d00", "fontStyle": "bold" }
        },
        {
            "name": "Strings",
            "scope": ["string.quoted"],
            "settings": { "foreground": "#ff9e00" }
        },
        {
            "name": "Numbers",
            "scope": ["constant.numeric"],
            "settings": { "foreground": "#ffcdb2" }
        },
        {
            "name": "Functions",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#ff0000" }
        },
        {
            "name": "AI Support Functions",
            "scope": ["support.function.fiber"],
            "settings": { "foreground": "#ffb703", "fontStyle": "bold" }
        },
        {
            "name": "Constants",
            "scope": ["constant.language"],
            "settings": { "foreground": "#d00000" }
        }
    ]
}
