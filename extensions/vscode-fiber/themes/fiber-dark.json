{
    "name": "Fiber Branded Dark",
    "type": "dark",
    "colors": {
        "editor.background": "#0d1117",
        "editor.foreground": "#c9d1d9",
        "activityBar.background": "#010409",
        "sideBar.background": "#0d1117",
        "statusBar.background": "#010409",
        "editorLineNumber.foreground": "#8b949e",
        "editorCursor.foreground": "#58a6ff"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#8b949e", "fontStyle": "italic" }
        },
        {
            "name": "Keywords",
            "scope": ["keyword.control", "storage.type"],
            "settings": { "foreground": "#ff7b72" }
        },
        {
            "name": "Strings",
            "scope": ["string.quoted"],
            "settings": { "foreground": "#a5d6ff" }
        },
        {
            "name": "Numbers",
            "scope": ["constant.numeric"],
            "settings": { "foreground": "#79c0ff" }
        },
        {
            "name": "Functions",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#d2a8ff" }
        },
        {
            "name": "AI Support Functions",
            "scope": ["support.function.fiber"],
            "settings": { "foreground": "#7ee787", "fontStyle": "bold" }
        },
        {
            "name": "Constants",
            "scope": ["constant.language"],
            "settings": { "foreground": "#ffab70" }
        }
    ]
}
