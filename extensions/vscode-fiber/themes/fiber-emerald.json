{
    "name": "Fiber Emerald",
    "type": "dark",
    "colors": {
        "editor.background": "#062016",
        "editor.foreground": "#e0f2f1",
        "activityBar.background": "#02120b",
        "sideBar.background": "#062016",
        "statusBar.background": "#02120b",
        "editorLineNumber.foreground": "#4d7c6b",
        "editorCursor.foreground": "#00ff9d"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#5c8a74", "fontStyle": "italic" }
        },
        {
            "name": "Keywords",
            "scope": ["keyword.control", "storage.type"],
            "settings": { "foreground": "#00ff9d", "fontStyle": "bold" }
        },
        {
            "name": "Strings",
            "scope": ["string.quoted"],
            "settings": { "foreground": "#80cbc4" }
        },
        {
            "name": "Numbers",
            "scope": ["constant.numeric"],
            "settings": { "foreground": "#a7ffeb" }
        },
        {
            "name": "Functions",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#4db6ac" }
        },
        {
            "name": "AI Support Functions",
            "scope": ["support.function.fiber"],
            "settings": { "foreground": "#b9f6ca", "fontStyle": "bold" }
        },
        {
            "name": "Constants",
            "scope": ["constant.language"],
            "settings": { "foreground": "#ffcc80" }
        }
    ]
}
