{
    "name": "Fiber Ocean",
    "type": "dark",
    "colors": {
        "editor.background": "#001219",
        "editor.foreground": "#e9d8a6",
        "activityBar.background": "#001219",
        "sideBar.background": "#001219",
        "statusBar.background": "#001219",
        "editorLineNumber.foreground": "#005f73",
        "editorCursor.foreground": "#94d2bd"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#005f73", "fontStyle": "italic" }
        },
        {
            "name": "Keywords",
            "scope": ["keyword.control", "storage.type"],
            "settings": { "foreground": "#00b4d8", "fontStyle": "bold" }
        },
        {
            "name": "Strings",
            "scope": ["string.quoted"],
            "settings": { "foreground": "#94d2bd" }
        },
        {
            "name": "Numbers",
            "scope": ["constant.numeric"],
            "settings": { "foreground": "#ee9b00" }
        },
        {
            "name": "Functions",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#00b4d8" }
        },
        {
            "name": "AI Support Functions",
            "scope": ["support.function.fiber"],
            "settings": { "foreground": "#94d2bd", "fontStyle": "bold" }
        },
        {
            "name": "Constants",
            "scope": ["constant.language"],
            "settings": { "foreground": "#bb3e03" }
        }
    ]
}
