{
    "name": "Fiber Fall",
    "type": "dark",
    "colors": {
        "editor.background": "#1b1401",
        "editor.foreground": "#fcefb4",
        "activityBar.background": "#1b1401",
        "sideBar.background": "#1b1401",
        "statusBar.background": "#1b1401",
        "editorLineNumber.foreground": "#5d4037",
        "editorCursor.foreground": "#f9a825"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#5d4037", "fontStyle": "italic" }
        },
        {
            "name": "Keywords",
            "scope": ["keyword.control", "storage.type"],
            "settings": { "foreground": "#d84315", "fontStyle": "bold" }
        },
        {
            "name": "Strings",
            "scope": ["string.quoted"],
            "settings": { "foreground": "#c0ca33" }
        },
        {
            "name": "Numbers",
            "scope": ["constant.numeric"],
            "settings": { "foreground": "#ffd54f" }
        },
        {
            "name": "Functions",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#f9a825" }
        },
        {
            "name": "AI Support Functions",
            "scope": ["support.function.fiber"],
            "settings": { "foreground": "#8bc34a", "fontStyle": "bold" }
        },
        {
            "name": "Constants",
            "scope": ["constant.language"],
            "settings": { "foreground": "#bf360c" }
        }
    ]
}
