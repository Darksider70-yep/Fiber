{
    "name": "fiber-vscode",
    "displayName": "Fiber: High-Performance Neuro-Symbolic IDE",
    "description": "Professional support for the Fiber language: High-performance Neural & Symbolic computing.",
    "version": "4.1.2",
    "publisher": "daksh-gehlot",
    "main": "./src/extension.js",
    "engines": {
        "vscode": "^1.75.0"
    },
    "activationEvents": [
        "onLanguage:fiber",
        "onCommand:fiber.buildToExe"
    ],
    "categories": [
        "Programming Languages",
        "Snippets",
        "Themes"
    ],
    "keywords": [
        "fiber",
        "neural",
        "symbolic",
        "ai",
        "logic"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Darksider70-yep/Fiber"
    },
    "bugs": {
        "url": "https://github.com/Darksider70-yep/Fiber/issues"
    },
    "icon": "icon.png",
    "license": "MIT",
    "contributes": {
        "commands": [
            {
                "command": "fiber.buildToExe",
                "title": "Build to Executable (EXE)",
                "category": "Fiber"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "fiber.buildToExe",
                    "when": "resourceExtname == .fib",
                    "group": "build@1"
                }
            ],
            "explorer/context": [
                {
                    "command": "fiber.buildToExe",
                    "when": "resourceExtname == .fib",
                    "group": "build@1"
                }
            ]
        },
        "languages": [
            {
                "id": "fiber",
                "aliases": [
                    "Fiber",
                    "fiber"
                ],
                "extensions": [
                    ".fib"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "fiber",
                "scopeName": "source.fiber",
                "path": "./syntaxes/fiber.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "fiber",
                "path": "./snippets/snippets.json"
            }
        ],
        "themes": [
            {
                "label": "Fiber Branded Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/fiber-dark.json"
            },
            {
                "label": "Fiber Emerald",
                "uiTheme": "vs-dark",
                "path": "./themes/fiber-emerald.json"
            },
            {
                "label": "Fiber Ocean",
                "uiTheme": "vs-dark",
                "path": "./themes/fiber-ocean.json"
            },
            {
                "label": "Fiber Sunset",
                "uiTheme": "vs-dark",
                "path": "./themes/fiber-sunset.json"
            },
            {
                "label": "Fiber Fall",
                "uiTheme": "vs-dark",
                "path": "./themes/fiber-fall.json"
            },
            {
                "label": "Fiber Astro",
                "uiTheme": "vs-dark",
                "path": "./themes/fiber-astro.json"
            }
        ],
        "configuration": {
            "title": "Fiber",
            "properties": {
                "fiber.path": {
                    "type": "string",
                    "default": "fiber",
                    "description": "Path to the Fiber executable (fiber.exe). If it's already in your system PATH, you can leave this as 'fiber'."
                }
            }
        }
    }
}
